# Malaysia ERP — Environment Variables Reference
# Copy these into Vercel → Project Settings → Environment Variables

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://..."          # Your Supabase connection string

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="<generate: openssl rand -hex 32>"
NEXTAUTH_URL="https://nexa-erp.com"     # Your production domain
JWT_SECRET="<generate: openssl rand -hex 32>"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."                  # From resend.com → API Keys
EMAIL_FROM="noreply@nexa-erp.com"        # Must match verified domain in Resend

# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,write_products,read_orders,write_orders,read_inventory,write_inventory"

# ─── TikTok Shop ─────────────────────────────────────────────────────────────
TIKTOK_APP_KEY=""
TIKTOK_APP_SECRET=""

# ─── Shopee Malaysia ─────────────────────────────────────────────────────────
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""

# ─── Lazada Malaysia ─────────────────────────────────────────────────────────
LAZADA_APP_KEY=""
LAZADA_APP_SECRET=""

# ─── Amazon SP-API (Malaysia) ─────────────────────────────────────────────────
AMAZON_MARKETPLACE_ID="A15PK738MTTZSY"
AMAZON_ENDPOINT="https://sellingpartnerapi-fe.amazon.com"
