// Malaysia Multi-Channel ERP System - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ORGANIZATIONS (Multi-tenant)
// ============================================================

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  integrations PlatformIntegration[]
  products     Product[]
  orders       Order[]
  customers    Customer[]
  warehouses   Warehouse[]
}

// ============================================================
// AUTH
// ============================================================

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  password      String
  role          UserRole     @default(STAFF)
  avatar        String?
  orgId         String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions      Session[]
  activityLogs  ActivityLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

// ============================================================
// PLATFORM INTEGRATIONS
// ============================================================

model PlatformIntegration {
  id            String           @id @default(cuid())
  platform      Platform
  name          String
  isActive      Boolean          @default(false)
  credentials   Json
  settings      Json?
  lastSyncAt    DateTime?
  orgId         String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  org           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs      SyncLog[]
  orders        Order[]
  products      ChannelProduct[]

  @@unique([platform, orgId])
}

enum Platform {
  SHOPIFY
  TIKTOK
  SHOPEE
  LAZADA
  AMAZON
}

model SyncLog {
  id            String              @id @default(cuid())
  integrationId String
  type          SyncType
  status        SyncStatus
  message       String?
  recordsCount  Int                 @default(0)
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  integration   PlatformIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

enum SyncType {
  PRODUCTS
  ORDERS
  INVENTORY
  CUSTOMERS
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id              String           @id @default(cuid())
  sku             String
  name            String
  description     String?
  category        String?
  brand           String?
  costPrice       Decimal          @db.Decimal(10, 2)
  weight          Decimal?         @db.Decimal(8, 3)
  weightUnit      String           @default("kg")
  images          String[]
  tags            String[]
  isActive        Boolean          @default(true)
  orgId           String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variants        ProductVariant[]
  channelProducts ChannelProduct[]
  inventoryItems  InventoryItem[]

  @@unique([sku, orgId])
}

model ProductVariant {
  id              String           @id @default(cuid())
  productId       String
  sku             String
  name            String
  attributes      Json
  costPrice       Decimal          @db.Decimal(10, 2)
  weight          Decimal?         @db.Decimal(8, 3)
  images          String[]
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelVariants ChannelVariant[]
  inventoryItems  InventoryItem[]
  orderItems      OrderItem[]

  @@unique([sku, productId])
}

model ChannelProduct {
  id              String               @id @default(cuid())
  productId       String
  integrationId   String
  externalId      String
  externalUrl     String?
  sellingPrice    Decimal              @db.Decimal(10, 2)
  status          ChannelProductStatus @default(ACTIVE)
  syncedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  integration     PlatformIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  channelVariants ChannelVariant[]

  @@unique([productId, integrationId])
}

model ChannelVariant {
  id               String         @id @default(cuid())
  channelProductId String
  variantId        String
  externalId       String
  sellingPrice     Decimal        @db.Decimal(10, 2)
  stock            Int            @default(0)
  syncedAt         DateTime?
  channelProduct   ChannelProduct @relation(fields: [channelProductId], references: [id], onDelete: Cascade)
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

enum ChannelProductStatus {
  ACTIVE
  INACTIVE
  PENDING
  BANNED
}

// ============================================================
// INVENTORY
// ============================================================

model Warehouse {
  id             String          @id @default(cuid())
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  country        String          @default("Malaysia")
  isDefault      Boolean         @default(false)
  orgId          String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@unique([code, orgId])
}

model InventoryItem {
  id           String              @id @default(cuid())
  productId    String
  variantId    String?
  warehouseId  String
  quantity     Int                 @default(0)
  reservedQty  Int                 @default(0)
  reorderPoint Int                 @default(10)
  reorderQty   Int                 @default(50)
  updatedAt    DateTime            @updatedAt
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant?     @relation(fields: [variantId], references: [id])
  warehouse    Warehouse           @relation(fields: [warehouseId], references: [id])
  movements    InventoryMovement[]

  @@unique([productId, variantId, warehouseId])
}

model InventoryMovement {
  id              String        @id @default(cuid())
  inventoryItemId String
  type            MovementType
  quantity        Int
  reason          String?
  reference       String?
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RESERVED
  RELEASED
}

// ============================================================
// ORDERS
// ============================================================

model Customer {
  id          String       @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  postcode    String?
  country     String       @default("Malaysia")
  platform    Platform?
  externalId  String?
  totalOrders Int          @default(0)
  totalSpent  Decimal      @default(0) @db.Decimal(12, 2)
  orgId       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([platform, externalId, orgId])
}

model Order {
  id                String               @id @default(cuid())
  orderNumber       String
  externalId        String?
  integrationId     String?
  customerId        String?
  status            OrderStatus          @default(PENDING)
  paymentStatus     PaymentStatus        @default(PENDING)
  fulfillmentStatus FulfillmentStatus    @default(UNFULFILLED)
  currency          String               @default("MYR")
  subtotal          Decimal              @db.Decimal(12, 2)
  shippingFee       Decimal              @default(0) @db.Decimal(10, 2)
  discount          Decimal              @default(0) @db.Decimal(10, 2)
  tax               Decimal              @default(0) @db.Decimal(10, 2)
  total             Decimal              @db.Decimal(12, 2)
  notes             String?
  shippingAddress   Json?
  trackingNumber    String?
  carrier           String?
  placedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  orgId             String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  org               Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integration       PlatformIntegration? @relation(fields: [integrationId], references: [id])
  customer          Customer?            @relation(fields: [customerId], references: [id])
  items             OrderItem[]

  @@unique([orderNumber, orgId])
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  variantId  String?
  externalId String?
  name       String
  sku        String?
  quantity   Int
  unitPrice  Decimal         @db.Decimal(10, 2)
  total      Decimal         @db.Decimal(12, 2)
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  RETURNED
}

// ============================================================
// ACTIVITY LOG
// ============================================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
